<Window x:Class="MaXSyncConfig.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaXSyncConfig"
        mc:Ignorable="d"
        Title="MaXSync — Configurare Agent Saga"
        Height="780" Width="900"
        MinHeight="720" MinWidth="820"
        Background="{StaticResource CreamBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource OliveBrush}" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="MaXSync"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="Agent sincronizare Saga ↔ MaXPos"
                               Foreground="#D9E2CC"
                               FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ServiceStatusDot"
                             Width="12" Height="12"
                             Fill="#888"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />
                    <TextBlock x:Name="ServiceStatusText"
                               Text="Serviciu: necunoscut"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="20"
                    Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource FlatTabItem}" />
            </TabControl.Resources>

            <!-- TAB 1: MaXPos -->
            <TabItem Header="MaXPos">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <Label Style="{StaticResource FieldLabel}" Content="URL API MaXPos" />
                        <TextBox x:Name="TxtBaseUrl" Style="{StaticResource FlatTextBox}" Margin="0,0,0,12" />

                        <Label Style="{StaticResource FieldLabel}" Content="Email cont" />
                        <TextBox x:Name="TxtEmail" Style="{StaticResource FlatTextBox}" Margin="0,0,0,12" />

                        <Label Style="{StaticResource FieldLabel}" Content="Parolă cont" />
                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource FlatPasswordBox}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Style="{StaticResource FieldLabel}" Content="Interval sync articole (minute)" />
                                <TextBox x:Name="TxtArticleInterval" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Style="{StaticResource FieldLabel}" Content="Interval export bonuri (minute)" />
                                <TextBox x:Name="TxtReceiptInterval" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="BtnTestApi"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="Testează conexiunea"
                                    Click="BtnTestApi_Click" />
                            <TextBlock x:Name="LblTestApiResult"
                                       VerticalAlignment="Center"
                                       Margin="14,0,0,0"
                                       FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Firebird -->
            <TabItem Header="Firebird / Saga">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Style="{StaticResource FieldLabel}" Content="Server Firebird" />
                                <TextBox x:Name="TxtFbHost" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Style="{StaticResource FieldLabel}" Content="Port" />
                                <TextBox x:Name="TxtFbPort" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                        </Grid>

                        <Label Style="{StaticResource FieldLabel}" Content="Cale bază de date (.fdb)" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtFbDatabase" Grid.Column="0" Style="{StaticResource FlatTextBox}" />
                            <Button x:Name="BtnBrowseDatabase"
                                    Grid.Column="2"
                                    Style="{StaticResource FlatButton}"
                                    Content="Răsfoiește..."
                                    Click="BtnBrowseDatabase_Click" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Style="{StaticResource FieldLabel}" Content="Utilizator" />
                                <TextBox x:Name="TxtFbUser" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Style="{StaticResource FieldLabel}" Content="Parolă Firebird" />
                                <PasswordBox x:Name="TxtFbPassword" Style="{StaticResource FlatPasswordBox}" />
                            </StackPanel>
                        </Grid>

                        <Label Style="{StaticResource FieldLabel}" Content="Charset" />
                        <ComboBox x:Name="CmbFbCharset" Style="{StaticResource FlatComboBox}" Margin="0,0,0,12">
                            <ComboBoxItem Content="UTF8" />
                            <ComboBoxItem Content="WIN1252" />
                            <ComboBoxItem Content="NONE" />
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="BtnTestFirebird"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="Testează conexiunea Firebird"
                                    Click="BtnTestFirebird_Click" />
                            <TextBlock x:Name="LblTestFbResult"
                                       VerticalAlignment="Center"
                                       Margin="14,0,0,0"
                                       FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: Sync options -->
            <TabItem Header="Opțiuni sincronizare">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <Label Style="{StaticResource FieldLabel}" Content="Prefix număr bon în Saga (ex: MXPS)" />
                        <TextBox x:Name="TxtReceiptPrefix" Style="{StaticResource FlatTextBox}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Style="{StaticResource FieldLabel}" Content="Cod client implicit (ex: DIVERSE)" />
                                <TextBox x:Name="TxtDefaultClientCode" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Style="{StaticResource FieldLabel}" Content="Denumire client implicit" />
                                <TextBox x:Name="TxtDefaultClientName" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Style="{StaticResource FieldLabel}" Content="Cod gestiune implicită (ex: 0001)" />
                                <TextBox x:Name="TxtDefaultGestiuneCode" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Style="{StaticResource FieldLabel}" Content="Denumire gestiune implicită" />
                                <TextBox x:Name="TxtDefaultGestiuneName" Style="{StaticResource FlatTextBox}" />
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="ChkSyncOnlyActive"
                                  Style="{StaticResource FlatCheckBox}"
                                  Content="Sincronizează doar articole active (BLOCAT = 0)"
                                  Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- SERVICE CONTROL -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Control serviciu Windows"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="LblServiceHint"
                               Text=""
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnServiceStart"
                            Style="{StaticResource SuccessButton}"
                            Content="Pornește serviciul"
                            Margin="0,0,8,0"
                            Click="BtnServiceStart_Click" />
                    <Button x:Name="BtnServiceStop"
                            Style="{StaticResource DangerButton}"
                            Content="Oprește serviciul"
                            Margin="0,0,8,0"
                            Click="BtnServiceStop_Click" />
                    <Button x:Name="BtnServiceRestart"
                            Style="{StaticResource WarningButton}"
                            Content="Repornește serviciul"
                            Click="BtnServiceRestart_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="3" Background="{StaticResource CreamDarkBrush}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblConfigPath"
                               Text="Configurație: ..."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="LblSavedToast"
                               Text=""
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Visibility="Collapsed" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnCancel"
                            Style="{StaticResource FlatButton}"
                            Content="Anulează"
                            Margin="0,0,8,0"
                            Click="BtnCancel_Click" />
                    <Button x:Name="BtnSave"
                            Style="{StaticResource PrimaryButton}"
                            Content="Salvează"
                            Click="BtnSave_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
